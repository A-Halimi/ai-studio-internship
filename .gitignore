# Data downloaded at runtime (use scripts/download_data.py)
data/
!data/.gitkeep

# Instructor answer key — NEVER pushed to the public GitHub repo. Kept on disk,
# baked into the :instructor Docker image, and excluded from the student image
# via .dockerignore. Regenerate student notebooks with scripts/make_student_notebooks.py.
solutions/

# Student-trained models (regenerated by running the notebooks)
ai_studio/models/*
!ai_studio/models/.gitkeep

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
venv/

# OS / editor noise
.DS_Store
Thumbs.db
*.stackdump

# Smoke-test artifacts
.smoke_out/

# Big dataset tarball kept in the Docker build context (re-download with
# scripts/download_data.py or let the build fetch it from the mirror)
docker/cifar-10-python.tar.gz
