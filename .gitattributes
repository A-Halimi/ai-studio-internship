# Normalize line endings; shell scripts and notebooks must stay LF so they
# work inside the Linux container even when checked out on Windows.
* text=auto
*.sh text eol=lf
*.py text eol=lf
*.ipynb text eol=lf
*.html text eol=lf
*.md text eol=lf
*.ps1 text eol=crlf
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.pdf binary
*.pt binary
*.npy binary
*.zip binary
*.joblib binary
